{
  "name": "3cucharadas-catastro-sii-maps",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "build:catastro": "vite build --config vite.catastro.config.ts",
    "dev:catastro": "vite --config vite.catastro.config.ts",
