{
  "version": 8,
  "name": "3 Cucharadas · Protomaps Chile",
  "glyphs": "fonts/{fontstack}/{range}.pbf",
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "__BASEMAP_PM_TILES__",
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {"background-color": "#eef2f3"}
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {"fill-color": "#eef2f3"}
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "paint": {"fill-color": "#d8e5d7", "fill-opacity": 0.72}
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "paint": {"fill-color": "#e2e9df", "fill-opacity": 0.78}
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {"fill-color": "#b8d9e7", "fill-opacity": 0.94}
    },
    {
      "id": "roads-glow",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "minor_road"]]],
      "paint": {
        "line-color": "#aebfc7",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.14, 10, 0.38, 16, 0.8],
        "line-blur": ["interpolate", ["linear"], ["zoom"], 4, 0, 13, 0.25, 16, 0.45],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.6, 10, 2.0, 16, 5.4]
      }
    },
    {
      "id": "roads-neon-core",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", ["get", "kind"], ["literal", ["highway", "major_road", "minor_road"]]],
      "paint": {
        "line-color": "#ffffff",
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 4, 0.35, 10, 0.88, 16, 0.98],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.22, 10, 0.72, 16, 2.0]
      }
    },
    {
      "id": "places-cities",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", ["get", "kind_detail"], ["literal", ["city", "town", "village"]]],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 12, 13, 15],
        "text-max-width": 9,
        "text-letter-spacing": 0.025,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#2a4352",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.25,
        "text-halo-blur": 0.45
      }
    }
  ]
}
