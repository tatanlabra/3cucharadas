# No guardar valores reales, tokens ni credenciales en Git.
SITE_REPO="/ruta/local/al/repositorio/3cucharadas"
SITE_BRANCH="feature/catastro-sii-mapas"

REMOTE_BUILD_HOST="stata01"
# Debe existir en un filesystem con uso <90%; no usar el árbol canónico como salida.
REMOTE_BUILD_ROOT="/mnt/nas05/proyecto_catastral_sii/outputs/maps/catastro_sii_brechas_maps"
SITE_SOURCE_DIR="${REMOTE_BUILD_ROOT}/site"
TILES_OUTPUT_ROOT="${REMOTE_BUILD_ROOT}/tiles"
# Tippecanoe requiere locks SQLite; construir en disco local ejecutable y copiar
# a TILES_OUTPUT_ROOT sólo tras validar el artefacto no publicado.
BUILD_WORK_ROOT="/tmp/catastro_sii_pmtiles_build"
# El límite normal es 90. Un override sólo se declara en la configuración no versionada,
# con motivo, espacio libre registrado y rollback comprobado.
MAX_VOLUME_USAGE_PCT="90"
# El entorno mantenido vive en stata01; no crear ni clonar Conda en volúmenes de datos.
PYTHON_BIN="/opt/conda/envs/python_base/bin/python"
CONDA_BIN="/usr/bin/conda"

# Insumos canónicos: se usan sólo en el entorno de build.
PREDIOS_SOURCE_DIR="/ruta/a/source_safe/tienda/v46_20260627/parquet"
COMUNAS_SOURCE="/ruta/a/DPA_2023_comunas.shp"
# DPA 2023 usa CUT_COM. El dataset tiene 345 geometrías; se declara la exclusión
# de Antártica Chilena (12202) en vez de descartarla silenciosamente.
COMUNAS_SOURCE_CODE_FIELD="CUT_COM"
COMUNAS_EXCLUDED_CODES="12202"
METRICAS_COMUNALES_SOURCE="/ruta/al/sitio/catastro_sii_brecha/data/comunas.json"
PROTOMAPS_SOURCE="/ruta/a/protomaps-planet.pmtiles"

PUBLIC_TILES_BASE="https://tiles.3cucharadas.cl/catastro-sii"
R2_BUCKET="3cucharadas-tiles"
R2_PREFIX="catastro-sii"
R2_REMOTE="r2"

# Sólo AUTHORIZED_VECTOR permite publicar PMTiles prediales.
LEGAL_PUBLICATION_STATUS="PENDING"
