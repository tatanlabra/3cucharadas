---
layout: null
permalink: /sitemap.xml
sitemap: false
---
{%- assign base = site.url | append: site.baseurl -%}
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url><loc>{{ base }}/catastro_sii_brecha/</loc></url>
  <url><loc>{{ base }}/catastro_sii_brecha/metodologia.html</loc></url>
{%- comment -%} Posts (cada uno con su par ES/EN bajo el mismo permalink) {%- endcomment -%}
{%- for post in site.posts -%}
  {%- assign es = base | append: post.url -%}
  {%- assign en = base | append: '/en' | append: post.url -%}
  {%- assign lm = post.last_modified_at | default: post.date | date_to_xmlschema -%}
  <url>
    <loc>{{ es }}</loc>
    {%- if lm %}<lastmod>{{ lm }}</lastmod>{% endif %}
    <xhtml:link rel="alternate" hreflang="es" href="{{ es }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ en }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ es }}"/>
  </url>
  <url>
    <loc>{{ en }}</loc>
    {%- if lm %}<lastmod>{{ lm }}</lastmod>{% endif %}
    <xhtml:link rel="alternate" hreflang="es" href="{{ es }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ en }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ es }}"/>
  </url>
{%- endfor -%}
{%- comment -%} Páginas indexables (excluye feeds, assets, xml, 404 y las marcadas sitemap:false) {%- endcomment -%}
{%- for page in site.pages -%}
  {%- unless page.sitemap == false or page.url contains '/assets/' or page.url contains '/deploy/' or page.url contains '/docs/' or page.url contains '.xml' or page.url contains '.txt' or page.url contains '404' or page.url contains '.json' -%}
  {%- assign es = base | append: page.url -%}
  {%- assign en = base | append: '/en' | append: page.url -%}
  {%- assign lm = page.last_modified_at | date_to_xmlschema -%}
  <url>
    <loc>{{ es }}</loc>
    {%- if lm %}<lastmod>{{ lm }}</lastmod>{% endif %}
    <xhtml:link rel="alternate" hreflang="es" href="{{ es }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ en }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ es }}"/>
  </url>
  <url>
    <loc>{{ en }}</loc>
    {%- if lm %}<lastmod>{{ lm }}</lastmod>{% endif %}
    <xhtml:link rel="alternate" hreflang="es" href="{{ es }}"/>
    <xhtml:link rel="alternate" hreflang="en" href="{{ en }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ es }}"/>
  </url>
  {%- endunless -%}
{%- endfor -%}
</urlset>
